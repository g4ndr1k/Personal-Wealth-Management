# Finance PWA environment variables
# Copy to .env.local and fill in your values before running `npm run dev` or `npm run build`.

# API key for the FastAPI backend (header: X-Api-Key).
# This value is embedded in the built JS bundle — do not use a high-value secret here.
# Access is protected at the network level by Tailscale; this key is a secondary check.
VITE_FINANCE_API_KEY=your-api-key-here
